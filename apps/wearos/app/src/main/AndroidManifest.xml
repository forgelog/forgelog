<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Rest-timer countdown ticks and the new-PR moment (Haptics.kt). -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="false"
        android:usesCleartextTraffic="false"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">

        <!-- Companion-required: routines/exercises/PR baselines only exist on the
             watch after the phone app pushes a sync snapshot (PhoneSyncListenerService).
             The local WAL lets an in-progress workout keep logging sets without the
             phone in range, but there's no watch-side routine creation, so a fresh
             install has nothing to do until it has synced with the phone at least
             once. Not standalone. -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <activity
            android:name="dev.bishnoi.forgelog.wear.MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.DeviceDefault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Receives routine/exercise/PR reference data pushed from the phone. -->
        <service
            android:name="dev.bishnoi.forgelog.wear.sync.PhoneSyncListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:scheme="wear"
                    android:host="*"
                    android:pathPrefix="/sync-snapshot" />
            </intent-filter>
        </service>

        <!-- Glanceable start/resume Tile: deferred to Phase 3. The
             androidx.wear.tiles / androidx.wear.protolayout API split in the
             current library version needs verifying against current docs
             before implementing (see .agents/plans/wearos-companion-plan.md). -->

    </application>
</manifest>
