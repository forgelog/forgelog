{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ExerciseType": {
      "type": "string",
      "enum": [
        "weight_reps",
        "reps_only",
        "weighted_bodyweight",
        "assisted_bodyweight",
        "duration",
        "duration_weight",
        "distance_duration",
        "weight_distance"
      ]
    },
    "LoggedSetPayload": {
      "type": "object",
      "required": ["id", "workout_exercise_id", "position", "set_type", "completed"],
      "properties": {
        "id": { "type": "string" },
        "workout_exercise_id": { "type": "string" },
        "position": { "type": "integer" },
        "set_type": { "type": "string", "enum": ["normal", "warmup", "dropset", "failure"] },
        "weight": { "type": ["number", "null"] },
        "reps": { "type": ["integer", "null"] },
        "duration_seconds": { "type": ["integer", "null"] },
        "distance_meters": { "type": ["number", "null"] },
        "rpe": { "type": ["number", "null"] },
        "completed": { "type": "boolean" },
        "completed_at": { "type": ["string", "null"] }
      }
    },
    "WorkoutExercisePayload": {
      "type": "object",
      "required": ["id", "exercise_id", "position", "exercise_type", "sets"],
      "properties": {
        "id": { "type": "string" },
        "exercise_id": { "type": "string" },
        "position": { "type": "integer" },
        "superset_group_id": { "type": ["string", "null"] },
        "exercise_type": { "$ref": "#/definitions/ExerciseType" },
        "notes": { "type": ["string", "null"] },
        "sets": {
          "type": "array",
          "items": { "$ref": "#/definitions/LoggedSetPayload" }
        }
      }
    },
    "WatchWorkoutPayload": {
      "type": "object",
      "required": ["protocol_version", "id", "name", "started_at", "exercises"],
      "properties": {
        "protocol_version": { "type": "integer", "const": 2 },
        "id": { "type": "string" },
        "routine_id": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "started_at": { "type": "string" },
        "ended_at": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] },
        "exercises": {
          "type": "array",
          "items": { "$ref": "#/definitions/WorkoutExercisePayload" }
        },
        "active_sync": {
          "type": "object",
          "required": ["finish_operation_id", "device_id", "device_sequence", "canonical_revision", "provisional", "payload_hash"],
          "properties": {
            "finish_operation_id": { "type": "string", "minLength": 1 },
            "device_id": { "type": "string", "minLength": 1 },
            "device_sequence": { "type": "integer", "minimum": 1 },
            "canonical_revision": { "type": ["integer", "null"], "minimum": 0 },
            "provisional": { "type": "boolean" },
            "payload_hash": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "ExerciseDto": {
      "type": "object",
      "required": ["id", "name", "exercise_type"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "exercise_type": { "$ref": "#/definitions/ExerciseType" }
      }
    },
    "RoutineSetDto": {
      "type": "object",
      "required": ["id", "routine_exercise_id", "position", "set_type"],
      "properties": {
        "id": { "type": "string" },
        "routine_exercise_id": { "type": "string" },
        "position": { "type": "integer" },
        "set_type": { "type": "string", "enum": ["normal", "warmup", "dropset", "failure"] },
        "target_weight": { "type": ["number", "null"] },
        "target_reps": { "type": ["integer", "null"] },
        "target_duration_seconds": { "type": ["integer", "null"] },
        "target_distance_meters": { "type": ["number", "null"] }
      }
    },
    "RoutineExerciseDetail": {
      "type": "object",
      "required": ["id", "routine_id", "exercise_id", "position", "exercise_type", "exercise", "sets"],
      "properties": {
        "id": { "type": "string" },
        "routine_id": { "type": "string" },
        "exercise_id": { "type": "string" },
        "position": { "type": "integer" },
        "superset_group_id": { "type": ["string", "null"] },
        "exercise_type": { "$ref": "#/definitions/ExerciseType" },
        "exercise": { "$ref": "#/definitions/ExerciseDto" },
        "sets": {
          "type": "array",
          "items": { "$ref": "#/definitions/RoutineSetDto" }
        }
      }
    },
    "RoutineDetail": {
      "type": "object",
      "required": ["id", "name", "position", "exercises"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "position": { "type": "integer" },
        "exercises": {
          "type": "array",
          "items": { "$ref": "#/definitions/RoutineExerciseDetail" }
        }
      }
    },
    "PersonalRecord": {
      "type": "object",
      "required": ["id", "exercise_id", "record_type", "value", "achieved_at"],
      "properties": {
        "id": { "type": "string" },
        "exercise_id": { "type": "string" },
        "record_type": { "type": "string", "enum": ["max_weight", "max_reps", "max_volume", "est_1rm"] },
        "value": { "type": "number" },
        "logged_set_id": { "type": ["string", "null"] },
        "achieved_at": { "type": "string" }
      }
    },
    "UserProfile": {
      "type": "object",
      "required": ["name", "sex", "birth_date", "height_cm", "bodyweight_kg"],
      "properties": {
        "name": { "type": "string" },
        "sex": { "type": ["string", "null"], "enum": ["male", "female", "prefer_not_to_say", null] },
        "birth_date": { "type": ["string", "null"] },
        "height_cm": { "type": ["number", "null"] },
        "bodyweight_kg": { "type": ["number", "null"] }
      }
    },
    "SyncSnapshot": {
      "type": "object",
      "required": ["protocol_version", "routines", "personalRecords", "profile"],
      "properties": {
        "protocol_version": { "type": "integer", "const": 2 },
        "routines": {
          "type": "array",
          "items": { "$ref": "#/definitions/RoutineDetail" }
        },
        "personalRecords": {
          "type": "array",
          "items": { "$ref": "#/definitions/PersonalRecord" }
        },
        "profile": { "$ref": "#/definitions/UserProfile" }
      }
    }
  }
}
